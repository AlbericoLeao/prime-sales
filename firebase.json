{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      { "source": "sw.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
      { "source": "**/*.@(js|css|svg|json)", "headers": [{ "key": "Cache-Control", "value": "public,max-age=3600" }] }
    ]
  },
  "firestore": { "rules": "firestore.rules" }
}
