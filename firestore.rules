rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn()
        && userDoc().exists()
        && userDoc().data.ativo != false
        && userDoc().data.bloqueado != true;
    }

    function role() {
      return activeUser() ? userDoc().data.role : null;
    }

    function admin() {
      return role() == 'admin';
    }

    function vendedor() {
      return role() == 'vendedor';
    }

    function activeProduct() {
      return resource.data.ativo == true;
    }

    function assignedClient(clienteId) {
      return clienteId is string
        && exists(/databases/$(database)/documents/clientes/$(clienteId))
        && get(/databases/$(database)/documents/clientes/$(clienteId)).data.vendedorId == request.auth.uid;
    }

    function validSellerOrderCreate() {
      return vendedor()
        && request.resource.data.vendedorId == request.auth.uid
        && request.resource.data.status == 'enviado'
        && assignedClient(request.resource.data.clienteId);
    }

    match /users/{uid} {
      allow read: if admin() || (signedIn() && request.auth.uid == uid);
      allow create, update, delete: if admin();
    }

    match /produtos/{id} {
      allow read: if admin() || (vendedor() && activeProduct());
      allow create, update, delete: if admin();
    }

    match /clientes/{id} {
      allow read: if admin() || (vendedor() && resource.data.vendedorId == request.auth.uid);
      allow create, update, delete: if admin();
    }

    match /pedidos/{id} {
      allow read: if admin() || (vendedor() && resource.data.vendedorId == request.auth.uid);
      allow create: if admin() || validSellerOrderCreate();
      allow update, delete: if admin();
    }
  }
}
