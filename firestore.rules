rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : '';
    }

    function admin() {
      return email() == 'albericoprestes2014@gmail.com';
    }

    function ownSellerDoc(sellerEmail) {
      return signedIn() && sellerEmail == email();
    }

    function activeSeller() {
      return signedIn()
        && exists(/databases/$(database)/documents/vendedores/$(email()))
        && get(/databases/$(database)/documents/vendedores/$(email())).data.status == 'ativo';
    }

    function activeProduct() {
      return resource.data.ativo == true
        || resource.data.status == 'ativo';
    }

    function assignedToSeller() {
      return activeSeller()
        && resource.data.vendedorEmail == email();
    }

    function assignedClient(clienteId) {
      return clienteId is string
        && exists(/databases/$(database)/documents/clientes/$(clienteId))
        && get(/databases/$(database)/documents/clientes/$(clienteId)).data.vendedorEmail == email();
    }

    function validSellerOrderCreate() {
      return activeSeller()
        && request.resource.data.vendedorEmail == email()
        && request.resource.data.status == 'pendente'
        && assignedClient(request.resource.data.clienteId);
    }

    function validAdminOrderDecision() {
      return admin()
        && resource.data.status == 'pendente'
        && request.resource.data.status in ['aprovado', 'rejeitado']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'historico', 'atualizadoEm', 'aprovadoEm', 'rejeitadoEm', 'estoqueBaixado'
        ]);
    }

    match /vendedores/{sellerEmail} {
      allow read: if admin() || ownSellerDoc(sellerEmail);
      allow create, update: if admin()
        && request.resource.data.email == sellerEmail
        && request.resource.data.status in ['ativo', 'bloqueado'];
      allow delete: if false;
    }

    match /produtos/{id} {
      allow read: if admin() || (activeSeller() && activeProduct());
      allow create, update: if admin();
      allow delete: if false;
    }

    match /clientes/{id} {
      allow read: if admin() || assignedToSeller();
      allow create, update: if admin();
      allow delete: if false;
    }

    match /pedidos/{id} {
      allow read: if admin() || assignedToSeller();
      allow create: if admin() || validSellerOrderCreate();
      allow update: if validAdminOrderDecision();
      allow delete: if false;
    }
  }
}
